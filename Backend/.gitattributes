# Git attributes for consistent line endings
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
.env* text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.pyc binary
*.pyo binary
*.so binary
*.dll binary
*.exe binary

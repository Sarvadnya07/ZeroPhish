# ZeroPhish Backend Environment Configuration

# Gateway Configuration
GATEWAY_PORT=8000
TIER3_TIMEOUT=5  # Max seconds to wait for AI analysis

# CORS Configuration (comma-separated origins)
# For development: include localhost and specific extension IDs
# For production: restrict to specific domains only
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# To allow a specific Chrome extension, add its origin to ALLOWED_ORIGINS:
# ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://your-extension-id-here

# Alternatively, use a regex to allow specific extension IDs (recommended for development with multiple IDs)
# ALLOW_ORIGIN_REGEX=chrome-extension://(extension-id-1|extension-id-2)

# Gemini API Key (Optional - for Tier 3 AI analysis)
# Get your key from: https://ai.google.dev/
# Note: The gateway works without this (Tier 3 will be disabled)
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# API Security (Optional - for production)
# API_KEY=your_secure_api_key_here

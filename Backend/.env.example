# ZeroPhish Backend Environment Configuration

# Gateway Configuration
GATEWAY_PORT=8000
TIER3_TIMEOUT=5  # Max seconds to wait for AI analysis

# CORS Configuration (comma-separated origins)
# For development: include localhost and chrome extension
# For production: restrict to specific domains
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,chrome-extension://*

# Gemini API Key (Optional - for Tier 3 AI analysis)
# Get your key from: https://ai.google.dev/
# Note: The gateway works without this (Tier 3 will be disabled)
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# API Security (Optional - for production)
# API_KEY=your_secure_api_key_here
